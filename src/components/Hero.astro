---
const { class: className } = Astro.props;
---

<section
  class:list={[
    "relative w-full max-w-[1440px] mx-auto px-4 md:px-8 py-6",
    className,
  ]}
>
  <div
    class="relative w-full overflow-hidden rounded-[40px] aspect-[16/9] md:aspect-[21/9] min-h-[400px]"
  >
    <!-- Background Image -->
    <div
      class="absolute inset-0 bg-cover bg-center transition-transform duration-700 hover:scale-105"
      style="background-image: url('/hero.jpg');"
    >
      <!-- Dark overlay for readability -->
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    <!-- Content -->
    <div class="relative h-full flex flex-col justify-center px-12 md:px-24">
      <!-- Brand Bars -->
      <div class="flex gap-2 mb-8">
        <div class="w-10 h-1.5 bg-brand-cyan rounded-full"></div>
        <div class="w-10 h-1.5 bg-brand-yellow rounded-full"></div>
        <div class="w-10 h-1.5 bg-brand-pink rounded-full"></div>
      </div>

      <!-- Typography -->
      <div class="max-w-2xl">
        <h1
          class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight"
        >
          Artistic Living at<br />Garda & Art
        </h1>
        <p
          class="text-lg md:text-xl text-white/90 mb-10 leading-relaxed font-light"
        >
          A curated stay where luxury meets vibrant design.<br />
          Experience our exclusive 2-bedroom private apartment.
        </p>

        <!-- CTA Button -->
        <a
          href="#booking"
          class="inline-block bg-brand-cyan text-white px-10 py-4 rounded-full font-bold text-lg shadow-lg hover:shadow-cyan-500/30 hover:scale-105 transition-all duration-300"
        >
          Rent Now
        </a>
      </div>
    </div>
  </div>
</section>
