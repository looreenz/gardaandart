---
interface Section {
  heading: string;
  text: string;
}

interface Props {
  id: string;
  title: string;
  closeLabel: string;
  sections: readonly Section[];
}

const { id, title, closeLabel, sections } = Astro.props;
---

<dialog
  id={id}
  class="legal-modal fixed inset-0 z-[200] w-full max-w-2xl m-auto p-0 bg-transparent backdrop:bg-black/60 backdrop:backdrop-blur-sm"
>
  <div
    class="bg-white rounded-[24px] shadow-2xl flex flex-col max-h-[85vh] overflow-hidden"
  >
    <!-- Header -->
    <div
      class="flex items-center justify-between px-7 py-5 border-b border-gray-100 shrink-0"
    >
      <div class="flex items-center gap-3">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-brand-cyan inline-block"
          ></span>
          <span class="w-3 h-3 rounded-full bg-brand-yellow inline-block"
          ></span>
          <span class="w-3 h-3 rounded-full bg-brand-pink inline-block"
          ></span>
        </div>
        <h2 class="font-bold text-lg text-brand-dark">{title}</h2>
      </div>
      <button
        data-modal-close={id}
        aria-label={closeLabel}
        class="w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors duration-200 cursor-pointer"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Scrollable body -->
    <div class="overflow-y-auto px-7 py-6 space-y-6">
      {
        sections.map((section) => (
          <div>
            <h3 class="font-bold text-sm tracking-wider uppercase text-brand-dark mb-2">
              {section.heading}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">{section.text}</p>
          </div>
        ))
      }
    </div>

    <!-- Footer -->
    <div
      class="px-7 py-4 border-t border-gray-100 shrink-0 flex justify-end"
    >
      <button
        data-modal-close={id}
        class="px-5 py-2 rounded-full bg-brand-dark text-white text-sm font-semibold hover:bg-brand-dark/80 transition-colors duration-200 cursor-pointer"
      >
        {closeLabel}
      </button>
    </div>
  </div>
</dialog>

<script>
  function initModal(dialog: HTMLDialogElement) {
    // Close on backdrop click
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    // Close buttons
    dialog
      .querySelectorAll<HTMLButtonElement>("[data-modal-close]")
      .forEach((btn) => btn.addEventListener("click", () => dialog.close()));
  }

  // Init on load and after Astro view transitions
  document.querySelectorAll<HTMLDialogElement>("dialog.legal-modal").forEach(initModal);
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLDialogElement>("dialog.legal-modal").forEach(initModal);
  });

  // Open triggers
  function initTriggers() {
    document.querySelectorAll<HTMLElement>("[data-modal-open]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.modalOpen!;
        const dialog = document.getElementById(id) as HTMLDialogElement | null;
        dialog?.showModal();
      });
    });
  }

  initTriggers();
  document.addEventListener("astro:page-load", initTriggers);
</script>
