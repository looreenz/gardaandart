---
import { reviews, overallScore, totalReviews } from "../data/reviews";
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale as "it" | "en" | "de" || "it";
const t = useTranslations(lang);
---

<section id="reviews" class="w-full bg-gray-50/80 py-16 md:py-28">
  <div class="max-w-[1440px] mx-auto px-4 md:px-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14">
      <div>
        <div class="flex gap-2 mb-4">
          <div class="w-10 h-1.5 bg-brand-cyan rounded-full"></div>
          <div class="w-10 h-1.5 bg-brand-yellow rounded-full"></div>
          <div class="w-10 h-1.5 bg-brand-pink rounded-full"></div>
        </div>
        <span class="text-xs font-bold tracking-[0.2em] text-brand-pink uppercase">{t("reviews.subtitle")}</span>
        <h2 class="text-4xl md:text-5xl font-bold text-brand-dark mt-2">{t("reviews.title")}</h2>
      </div>

      <!-- Overall Score -->
      <div class="flex items-center gap-5 bg-white rounded-2xl px-6 py-5 shadow-sm border border-brand-border w-fit">
        <div class="text-center">
          <span class="text-5xl font-bold text-brand-cyan">4.89</span>
          <p class="text-xs text-gray-500 font-medium mt-1">{t("reviews.outOf")}</p>
        </div>
        <div class="w-px h-12 bg-gray-200"></div>
        <div>
          <p class="font-bold text-brand-dark text-lg">{t("reviews.badge")}</p>
          <p class="text-sm text-gray-500">{totalReviews} {t("reviews.reviewsText")}</p>
          <div class="flex gap-1 mt-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-yellow fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Review Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {reviews.map((review) => (
        <div class="bg-white rounded-[24px] p-7 shadow-sm border border-brand-border hover:shadow-md transition-shadow duration-300">
          <!-- Score badge + meta -->
          <div class="flex items-start justify-between mb-5">
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-full bg-brand-cyan-soft flex items-center justify-center text-xl font-bold text-brand-cyan border-2 border-brand-cyan/20">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="font-bold text-brand-dark text-sm">{review.name} <span class="font-normal">{review.flag}</span></p>
                <p class="text-xs text-gray-400">{review.stayType} · {review.date}</p>
              </div>
            </div>
            <div class="bg-brand-cyan text-white text-sm font-bold px-3 py-1.5 rounded-xl">
              {review.score}
            </div>
          </div>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3.5 h-3.5 text-brand-yellow fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/></svg>
            ))}
          </div>

          <!-- Text -->
          <p class="text-gray-600 text-sm leading-relaxed font-light">"{review.text}"</p>
        </div>
      ))}
    </div>

    <!-- Airbnb Attribution -->
    <div class="mt-10 flex items-center gap-3 text-sm text-gray-400">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      <span>{t("reviews.attribution")}</span>
    </div>
  </div>
</section>
