---
const { class: className } = Astro.props;
---

<header
  class:list={[
    "w-full py-4 px-6 md:px-12 flex items-center justify-between bg-white",
    className,
  ]}
>
  <div class="flex items-center">
    <a href="/" class="flex items-center">
      <img
        src="/logo.JPG"
        alt="Garda & Art Logo"
        class="h-10 w-auto object-contain"
      />
    </a>
  </div>

  <nav class="hidden md:flex items-center space-x-8">
    <a
      href="#features"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Features</a
    >
    <a
      href="#second-page"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Second page</a
    >
    <a
      href="#customers"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Customers</a
    >
    <a
      href="#about-us"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >About us</a
    >
  </nav>

  <div class="flex items-center">
    <a
      href="#contact"
      class="bg-brand-cyan text-white px-6 py-2.5 rounded-full text-sm font-bold shadow-sm hover:shadow-md hover:scale-105 transition-all duration-300 active:scale-95"
    >
      Reach out to us
    </a>
  </div>
</header>
