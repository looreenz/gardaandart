---
const { class: className } = Astro.props;
---

<header
  class:list={[
    "w-full py-4 px-4 md:px-12 flex items-center justify-between bg-white relative z-50",
    className,
  ]}
>
  <div class="flex items-center">
    <a href="/" class="flex items-center">
      <img
        src="/logo.JPG"
        alt="Garda & Art Logo"
        class="h-8 md:h-10 w-auto object-contain"
      />
    </a>
  </div>

  <!-- Desktop Navigation -->
  <nav class="hidden md:flex items-center space-x-8">
    <a
      href="#features"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Features</a
    >
    <a
      href="#second-page"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Second page</a
    >
    <a
      href="#customers"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >Customers</a
    >
    <a
      href="#about-us"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >About us</a
    >
  </nav>

  <div class="flex items-center gap-4">
    <a
      href="#contact"
      class="bg-brand-cyan text-white px-4 md:px-6 py-2 md:py-2.5 rounded-full text-xs md:text-sm font-bold shadow-sm hover:shadow-md transition-all duration-300 active:scale-95"
    >
      <span class="hidden sm:inline">Reach out to us</span>
      <span class="sm:hidden text-[10px]">Contact</span>
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 focus:outline-none"
      aria-label="Toggle Menu"
    >
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[60] flex flex-col items-center justify-center space-y-8 translate-x-full transition-transform duration-500 ease-in-out"
  >
    <button
      id="close-menu-btn"
      class="absolute top-6 right-6 p-2 text-3xl text-brand-dark"
      >&times;</button
    >

    <a
      href="#features"
      class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
      >Features</a
    >
    <a
      href="#second-page"
      class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
      >Second page</a
    >
    <a
      href="#customers"
      class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
      >Customers</a
    >
    <a
      href="#about-us"
      class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
      >About us</a
    >

    <div class="flex gap-4 pt-4">
      <div class="w-3 h-3 bg-brand-cyan rounded-full"></div>
      <div class="w-3 h-3 bg-brand-yellow rounded-full"></div>
      <div class="w-3 h-3 bg-brand-pink rounded-full"></div>
    </div>
  </div>
</header>

<script>
  const openBtn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("close-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const links = document.querySelectorAll(".menu-link");

  function openMenu() {
    menu?.classList.remove("translate-x-full");
    document.body.classList.add("overflow-hidden");
  }

  function closeMenu() {
    menu?.classList.add("translate-x-full");
    document.body.classList.remove("overflow-hidden");
  }

  openBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  links.forEach((link) => link.addEventListener("click", closeMenu));
</script>
