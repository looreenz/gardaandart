---
import { getLocaleUrl, useTranslations } from "../i18n/utils";

const { class: className } = Astro.props;
const lang = (Astro.currentLocale as "it" | "en" | "de") || "it";
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const locales = [
  { code: "it", label: "IT", emoji: "🇮🇹" },
  { code: "de", label: "DE", emoji: "🇩🇪" },
  { code: "en", label: "EN", emoji: "🇬🇧" },
];
---

<header
  class:list={[
    "w-full py-4 px-4 md:px-12 flex items-center justify-between bg-white/90 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100/50",
    className,
  ]}
>
  <div class="flex items-center">
    <a href="/" class="flex items-center">
      <img
        src="/logo.JPG"
        alt="Garda & Art Logo"
        class="h-8 md:h-10 w-auto object-contain"
      />
    </a>
  </div>

  <!-- Desktop Navigation -->
  <nav class="hidden md:flex items-center space-x-8">
    <a
      href="#about"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >{t("nav.about")}</a
    >
    <a
      href="#amenities"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >{t("nav.amenities")}</a
    >
    <a
      href="#location"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >{t("nav.location")}</a
    >
    <a
      href="#reviews"
      class="text-sm font-medium text-gray-600 hover:text-brand-cyan transition-colors"
      >{t("nav.reviews")}</a
    >
  </nav>

  <div class="flex items-center gap-4">
    <!-- Language Switcher Desktop -->
    <div
      class="hidden md:flex items-center bg-gray-100 rounded-full px-4 py-1.5 space-x-3"
    >
      {
        locales.map((locale, i) => (
          <>
            <a
              href={getLocaleUrl(currentPath, locale.code)}
              class:list={[
                "text-xs font-bold transition-colors",
                lang === locale.code
                  ? "text-brand-cyan"
                  : "text-gray-400 hover:text-brand-dark",
              ]}
            >
              {locale.label}
            </a>
            {i < locales.length - 1 && (
              <span class="text-gray-300 text-xs">·</span>
            )}
          </>
        ))
      }
    </div>
    <a
      href="#contact"
      class="bg-brand-cyan text-white px-4 md:px-6 py-2 md:py-2.5 rounded-full text-xs md:text-sm font-bold shadow-sm hover:shadow-md transition-all duration-300 active:scale-95"
    >
      <span class="hidden sm:inline">{t("nav.booking") || "Book"}</span>
      <span class="sm:hidden text-[10px]"
        >{t("booking.contactUs") || "Contact"}</span
      >
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 focus:outline-none"
      aria-label="Toggle Menu"
    >
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
      <div class="w-6 h-0.5 bg-brand-dark transition-all duration-300"></div>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-white z-[60] flex flex-col items-center justify-center space-y-8 translate-x-full transition-transform duration-500 ease-in-out"
>
  <button
    id="close-menu-btn"
    class="absolute top-6 right-6 p-2 text-3xl text-brand-dark">&times;</button
  >

  <a
    href="#about"
    class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
    >{t("nav.about")}</a
  >
  <a
    href="#amenities"
    class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
    >{t("nav.amenities")}</a
  >
  <a
    href="#location"
    class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
    >{t("nav.location")}</a
  >
  <a
    href="#reviews"
    class="text-2xl font-bold text-brand-dark hover:text-brand-cyan transition-colors menu-link"
    >{t("nav.reviews")}</a
  >

  <div class="flex gap-6 pt-4 border-t border-gray-100 w-2/3 justify-center">
    {
      locales.map((locale) => (
        <a
          href={getLocaleUrl(currentPath, locale.code)}
          class:list={[
            "text-3xl transition-transform hover:scale-110",
            lang === locale.code
              ? "grayscale-0 ring-4 ring-brand-cyan/30 rounded-full"
              : "grayscale opacity-50",
          ]}
          title={locale.label}
        >
          {locale.emoji}
        </a>
      ))
    }
  </div>
</div>

<script>
  const openBtn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("close-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const links = document.querySelectorAll(".menu-link");

  function openMenu() {
    menu?.classList.remove("translate-x-full");
    document.body.classList.add("overflow-hidden");
  }

  function closeMenu() {
    menu?.classList.add("translate-x-full");
    document.body.classList.remove("overflow-hidden");
  }

  openBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  links.forEach((link) => link.addEventListener("click", closeMenu));
</script>
