---
import { useTranslations } from "../i18n/utils";

const bookingUrl =
  "https://www.booking.com/hotel/it/garda-amp-art-apartment.html";
const currentYear = new Date().getFullYear();
const lang = (Astro.currentLocale as "it" | "en" | "de") || "it";
const t = useTranslations(lang);
---

<footer id="contact" class="w-full bg-brand-dark text-white">
  <div class="max-w-[1440px] mx-auto px-4 md:px-8 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 mb-12">
      <!-- Brand -->
      <div class="space-y-5">
        <img
          src="/logo.JPG"
          alt="Garda & Art Logo"
          class="h-8 w-auto object-contain brightness-0 invert"
        />
        <p class="text-white/60 text-sm leading-relaxed font-light">
          A curated stay where art meets the beauty of Lake Garda. Designed for
          those who appreciate beauty in every detail.
        </p>
        <div class="flex gap-2">
          <div class="w-6 h-1 bg-brand-cyan rounded-full"></div>
          <div class="w-6 h-1 bg-brand-yellow rounded-full"></div>
          <div class="w-6 h-1 bg-brand-pink rounded-full"></div>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4
          class="font-bold text-sm tracking-widest uppercase mb-5 text-white/40"
        >
          Explore
        </h4>
        <ul class="space-y-3">
          {
            [
              { label: t("nav.about"), href: "#about" },
              { label: t("nav.amenities"), href: "#amenities" },
              { label: t("gallery.title"), href: "#gallery" },
              { label: t("nav.location"), href: "#location" },
              { label: t("nav.reviews"), href: "#reviews" },
              { label: t("houseRules.title"), href: "#rules" },
            ].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/60 hover:text-brand-cyan text-sm transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact & Book -->
      <div>
        <h4
          class="font-bold text-sm tracking-widest uppercase mb-5 text-white/40"
        >
          Book & Contact
        </h4>
        <div class="space-y-4 mb-6">
          <div class="flex items-center gap-3 text-sm text-white/60">
            <svg
              class="w-4 h-4 text-brand-cyan shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
              ></path></svg
            >
            Garda, Verona · Lake Garda, Italy
          </div>
          <div class="flex items-center gap-3 text-sm text-white/60">
            <svg
              class="w-4 h-4 text-brand-yellow shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
              ></path></svg
            >
            Check-in 3 PM · Check-out 11 AM
          </div>
          <div class="flex items-center gap-3 text-sm text-white/60">
            <svg
              class="w-4 h-4 text-brand-pink shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"
              ></path></svg
            >
            Up to 4 guests · 2 bedrooms
          </div>
        </div>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-brand-cyan text-white px-6 py-3 rounded-full font-bold text-sm hover:scale-105 transition-all duration-300 shadow-lg shadow-brand-cyan/20"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z"
            ></path></svg
          >
          Book Now
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-white/30 text-xs text-center md:text-left">
        © {currentYear} Garda & Art Apartment · {t("footer.rights")}
      </p>
      <div class="flex gap-4">
        <a
          href="#"
          class="text-white/30 text-xs hover:text-white/70 transition-colors"
          >{t("footer.privacy")}</a
        >
        <a
          href="#"
          class="text-white/30 text-xs hover:text-white/70 transition-colors"
          >{t("footer.terms")}</a
        >
      </div>
    </div>
  </div>
</footer>
