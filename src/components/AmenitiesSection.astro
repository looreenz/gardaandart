---

<section
  id="amenities"
  class="w-full max-w-[1440px] mx-auto px-4 md:px-8 py-12 md:py-24"
>
  <!-- Header -->
  <div class="mb-12 md:mb-16">
    <div class="flex gap-2 mb-4">
      <div class="w-10 h-1.5 bg-brand-cyan rounded-full"></div>
      <div class="w-10 h-1.5 bg-brand-yellow rounded-full"></div>
      <div class="w-10 h-1.5 bg-brand-pink rounded-full"></div>
    </div>
    <span class="text-xs font-bold tracking-[0.2em] text-brand-cyan uppercase"
      >{t("amenities.subtitle")}</span
    >
    <h2 class="text-4xl md:text-5xl font-bold text-brand-dark mt-2 mb-4">
      {t("amenities.title")}
    </h2>
    <p class="text-lg text-gray-500 font-light max-w-xl">
      {t("amenities.subtitle")}
    </p>
  </div>

  <!-- Grid -->
  <div
    class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4"
  >
    {
      amenities.map((amenity, i) => {
        const colors = [
          "bg-brand-cyan-soft text-brand-cyan border-brand-cyan/20",
          "bg-brand-yellow-soft text-brand-yellow border-brand-yellow/20",
          "bg-brand-pink-soft text-brand-pink border-brand-pink/20",
        ];
        const color = colors[i % 3];
        return (
          <div
            class:list={[
              "flex flex-col items-center gap-3 p-5 rounded-2xl border-2 hover:scale-105 transition-all duration-300 hover:shadow-lg cursor-default",
              color,
            ]}
          >
            <span
              class="[&>svg]:w-7 [&>svg]:h-7"
              set:html={icons[amenity.icon] ?? icons["key"]}
            />
            <span class="text-xs font-bold text-center text-gray-700 leading-tight">
              {t(`amenities.items.${amenity.icon}`)}
            </span>
          </div>
        );
      })
    }
  </div>
</section>
